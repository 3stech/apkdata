  "app_notes": {
    "schema_migration": "v2.0 replaces gregorian_date with date_rule on every festival entry. The app resolves dates using FestivalDateResolver at startup each Tamil year. Computed dates are cached in Room DB (festival_computed_dates table). See ThithiAlert_Festivals_DateRule_Spec_v1_0.md for full implementation details.",
    "gregorian_fixed_examples": "Republic Day (Jan 26) and Independence Day (Aug 15) are examples of gregorian_fixed type dates, suitable for future government holiday entries.",
    "purattasi_navratri_note": "Navratri tithi rules use Purattasi as the base month. In edge-case years the tithi may overflow into early Aippasi — the resolver must search forward from Purattasi Amavasai.",
    "skanda_shashthi_note": "Skanda Shashthi is a 6-day festival: s004 is day 1 (Karthigai Shukla Prathama), s003 is day 6 (Soorasamharam, Shukla Shashthi).",
    "same_date_entries": "u012 and v007 (Margazhi / Thirupavai) resolve to the same Gregorian date — they will be grouped in the RecyclerView per the grouping logic in FestivalsAdapter. Similarly u006 and v005 (Onam) share a date.",
    "weekday_occurrence_note": "tamil_month_weekday occurrence values are 1 (first), 2 (second), 3 (third), 4 (fourth). Use -1 for last occurrence (not used in current entries). Resolver must use Tamil month solar boundaries (sankranti dates) as month start/end.",
    "update_schedule": "This file is now year-agnostic. Update panchangam_ref text if canonical descriptions change. No annual re-date required — the resolver handles date calculation each year automatically."
  }
